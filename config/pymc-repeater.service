#Systemd service file for pyMC - Meshcore Repeater Daemon (clean install)
#Install as /etc/systemd/system/pymc-repeater.service

[Unit]
Description=pyMC Repeater Daemon
After=network-online.target
Wants=network-online.target

[Service]
User=__PI_USER__
Group=__PI_USER__
WorkingDirectory=/opt/pymc_repeater/repos/pyMC_Repeater
Environment="PYTHONPATH=/opt/pymc_repeater/repos/pyMC_Repeater"
Environment="VIRTUAL_ENV=/opt/pymc_repeater/venv"
Environment="PATH=/opt/pymc_repeater/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# Apply SPI bus stability optimizations (CPU governor, polling_limit, RT scheduling)
# Runs as root (+) because sysfs writes require elevated privileges
ExecStartPre=+/bin/bash /opt/pymc_repeater/spi_optimize.sh
# Stop any standalone lora_pkt_fwd service (may not exist; suppress errors)
ExecStartPre=-/bin/bash -c '/usr/bin/sudo /bin/systemctl stop lora_pkt_fwd.service 2>/dev/null || true'
ExecStartPre=/bin/bash -c 'for f in /tmp/pymc_spectral_results.json /tmp/pymc_wm1303_bridge_conf.json /tmp/pymc_cad_config.json; do touch "$f" && chown __PI_USER__:__PI_USER__ "$f" && chmod 664 "$f"; done 2>/dev/null || true'
ExecStart=/opt/pymc_repeater/venv/bin/python3 -m repeater.main --config /etc/pymc_repeater/config.yaml

# Service-level hardware watchdog (Type=notify):
# The backend sends sd_notify READY=1 once the RX watchdog thread is up, and
# WATCHDOG=1 every loop cycle (~5s). If no keepalive arrives within WatchdogSec,
# systemd considers the service hung and restarts it.
Type=notify
NotifyAccess=main
WatchdogSec=60
# Allow slow concentrator/HAL startup before READY=1 (no false-positive restart)
TimeoutStartSec=120

# Restart on failure AND on watchdog timeout
Restart=always
RestartSec=5

# Resource limits
MemoryHigh=256M

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pymc-repeater

# Security (relaxed for proper operation)
ReadWritePaths=/var/log/pymc_repeater /var/lib/pymc_repeater /etc/pymc_repeater __PI_HOME__ /tmp

[Install]
WantedBy=multi-user.target
